{
  "manifest_version": 3,
  "name": "YT Premium",
  "version": "1.0",
  "author":"tromoSM",
  "homepage_url":"https://github.com/tromoSM/YT-Premium-Patch",

  "description": " Youtube adblock and Premium logo for youtube.com",

  "icons": {
    "16": "icons/tromoSM_YT_Premium_16.png",
    "32": "icons/tromoSM_YT_Premium_32.png",
    "180":"icons/tromoSM_YT_Premium_180.png",
    "190":"icons/tromoSM_YT_Premium_512.png"
  },
  "host_permissions":["*://*.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["main.js"]
    }
  ]
}
